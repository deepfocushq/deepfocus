# Password required to unlock /admin
ADMIN_PASSWORD=change-me

# Optional: used to sign the admin session cookie. Falls back to ADMIN_PASSWORD if unset.
SESSION_SECRET=change-me-too

# Optional, production only: Vercel KV / Upstash Redis credentials.
# Without these, content is stored in data/content.json on disk (fine for local dev,
# but NOT persistent on Vercel's serverless filesystem). Add a Vercel KV / Upstash
# Redis integration in your Vercel project and these will be set automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=
