# Password required to unlock /admin
ADMIN_PASSWORD=change-me

# Optional: used to sign the admin session cookie. Falls back to ADMIN_PASSWORD if unset.
SESSION_SECRET=change-me-too

# Optional, production only: Neon Postgres connection string.
# Without this, content is stored in data/content.json on disk (fine for local dev,
# but NOT persistent on Vercel's serverless filesystem). Add the Neon integration in
# your Vercel project (or paste your Neon connection string) to set this automatically.
DATABASE_URL=

# Optional: Cloudflare R2 for image uploads in the admin panel.
# Without these, the admin panel still works — you just paste image URLs manually
# instead of uploading files.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public base URL that serves the bucket's objects (R2.dev dev URL, or a custom domain
# bound to the bucket in the Cloudflare dashboard). No trailing slash.
R2_PUBLIC_URL=

# Optional: Resend for actually sending the contact form (not just opening a mailto: link).
# Without this, the contact form falls back to opening the visitor's email client.
RESEND_API=
# Optional: sender address. Defaults to onboarding@resend.dev (works with zero setup).
# To send from your own domain, verify it in the Resend dashboard first.
RESEND_FROM_EMAIL=
